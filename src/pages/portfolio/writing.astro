    description: "",
    tag: "Substack",
  },
];
---

<BaseLayout title="Writing Portfolio" description="Selected essays and writing by Lily Luo">
  <p><a href="/portfolio">&larr; Portfolio</a></p>

  <h1>Writing</h1>
  <p class="text-muted">Selected essays. Published on <a href="https://lowyelling.substack.com" target="_blank" rel="noopener">Furniture Coins</a>.</p>

  <div class="essays mt-lg">
    {essays.map(({ title, url, description, tag }) => (
      <a href={url} target="_blank" rel="noopener" class="essay-card">
        <div class="essay-content">
          <h2>{title || "Essay Title"}</h2>
          <p class="essay-desc">{description || "Short description goes here."}</p>
        </div>
        <span class="essay-tag">{tag}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .essays {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .essay-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--spacing-md);
    padding: var(--spacing-lg);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .essay-card:hover {
    border-color: var(--color-accent);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .essay-content {
    flex: 1;
  }

  .essay-card h2 {
    color: var(--color-text);
    font-size: 1.1rem;
    margin-bottom: 0.35rem;
  }

  .essay-desc {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
    line-height: 1.5;
  }

  .essay-tag {
    flex-shrink: 0;
    font-size: 0.75rem;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
    margin-top: 0.15rem;
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const essays = [
  {
    title: "",
    url: "https://lowyelling.substack.com/",
    description: "",
    tag: "Substack",
  },
  {
    title: "",
    url: "https://lowyelling.substack.com/",
    description: "",
    tag: "Substack",
  },
  {
    title: "",
    url: "https://lowyelling.substack.com/",
    description: "",
    tag: "Substack",
  },
  {
    title: "",
    url: "https://lowyelling.substack.com/",
    description: "",
    tag: "Substack",
  },
  {
    title: "",
    url: "https://lowyelling.substack.com/",
    description: "",
    tag: "Substack",
  },
  {
    title: "",

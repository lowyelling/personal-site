---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Dev Portfolio" description="Software projects">
  <p><a href="/portfolio">&larr; Portfolio</a></p>

  <h1>Dev</h1>
  <p class="text-muted">Software projects</p>

  <div class="projects mt-lg">
    <div class="project-card goodbye-card">
      <img src="/images/blog/GoodbyeFriend.gif" alt="" class="goodbye-bg" />
      <div class="project-content">
        <h2>Goodbye Friend</h2>
        <p class="project-desc">A data story on the death of a decade long friendship.</p>
        <div class="project-links">
          <a href="https://goodbyefriend.vercel.app" target="_blank" rel="noopener" class="project-link">Live site &rarr;</a>
          <a href="https://www.lowyelling.com/blog/6-week-five-polish-a-product" class="project-link">Blog post</a>
        </div>
      </div>
    </div>

    <a href="https://www.lowyelling.com/blog" class="project-card blog-card">
      <div class="project-content">
        <h2>Fractal Tech NYC</h2>
        <p class="project-desc">12 weeks, 12 projects. My weekly blog posts explain.</p>
        <span class="project-link">Read the blog &rarr;</span>
      </div>
    </a>
  </div>
</BaseLayout>

<style>
  .projects {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-lg);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  a.project-card:hover {
    border-color: var(--color-accent);
    text-decoration: none;
    transform: translateY(-2px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .project-content {
    flex: 1;
  }

  .project-card h2 {
    color: var(--color-text);
    font-size: 1.1rem;
    margin-bottom: 0.35rem;
  }

  .project-desc {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0 0 var(--spacing-md) 0;
    line-height: 1.5;
  }

  .project-links {
    display: flex;
    gap: var(--spacing-md);
  }

  .project-link {
    font-size: 0.85rem;
    color: var(--color-accent);
  }

  .project-link:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }

  .goodbye-card {
    position: relative;
    overflow: hidden;
  }

  .goodbye-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.2;
    pointer-events: none;
  }

  .goodbye-card .project-content {
    position: relative;
  }
</style>
